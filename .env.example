# ── Backend ──────────────────────────────────────────────
PORT=3000

# ── WAHA (WhatsApp HTTP API) ─────────────────────────────
# Saat jalan via docker-compose, host WAHA = nama service "waha"
WAHA_URL=http://waha:3000
WAHA_SESSION=default
# API key WAHA (kosongkan jika WAHA tidak pakai API key)
WAHA_API_KEY=

# ── Filter Trigger ───────────────────────────────────────
# ID grup WhatsApp target. Format WAHA biasanya: 1203630xxxxxx@g.us
# Kosongkan untuk MENERIMA dari semua chat (mode uji). Isi untuk produksi.
TARGET_GROUP_ID=
# Kata kunci pemicu (pisahkan dengan koma). Pesan harus mengandung salah satu.
TRIGGER_KEYWORDS=Nominasi PGN,ReNominasi PGN

# ── Perilaku Balasan ─────────────────────────────────────
# true  = balas dengan ringkasan angka (Date | Swap | Stok | Total)
# false = balas singkat "Baik Pak, Data Re-Nominasi berhasil diinput"
REPLY_WITH_SUMMARY=true
# true = balas sebagai reply/quote ke pesan asli
REPLY_AS_QUOTE=true

# ── Email Microsoft 365 (Fase 2) ─────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
EMAIL_CC=
EMAIL_SUBJECT_PREFIX=Nominasi Gas CL
